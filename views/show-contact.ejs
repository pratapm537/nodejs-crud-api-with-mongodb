<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Details</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="stylesheet" href="/assets/show-contact-style.css">
</head>
<body>

<div class="container-fluid">
    <div class="card">
        <!-- Header -->
        <div class="card-header">
            <h4>Contact Details</h4>
        </div>

        <!-- Body -->
        <div class="card-body">
            
            <table class="table table-bordered align-middle mb-4">
                <tbody>
                    <tr>
                        <th scope="row" class="detail-label">First Name</th>
                        <td class="detail-value"><%= contact.first_name  %></td>
                    </tr>
                    <tr>
                        <th scope="row" class="detail-label">Last Name</th>
                        <td class="detail-value"><%= contact.last_name  %></td>
                    </tr>
                    <tr>
                        <th scope="row" class="detail-label">Email</th>
                        <td class="detail-value"><%= contact.email  %></td>
                    </tr>
                    <tr>
                        <th scope="row" class="detail-label">Phone</th>
                        <td class="detail-value"><%= contact.phone  %></td>
                    </tr>
                    <tr>
                        <th scope="row" class="detail-label">Address</th>
                        <td class="detail-value"><%= contact.address  %></td>
                    </tr>
                </tbody>
            </table>

            <hr>

            <!-- Actions -->
            <div class="row mt-3">
                <div class="col-sm-3"></div>
                <div class="col-sm-9">
                    <a href="/update-contact/<%= contact.id  %>" class="btn btn-custom btn-edit-action me-2">Edit</a >
                    <a href="/delete-contact/<%= contact.id  %>" class="btn btn-custom btn-delete-action me-2">Delete</a >
                    <a href="/" class="btn btn-custom btn-cancel-action">Cancel</a >
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap 5 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
