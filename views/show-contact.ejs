<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Details</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/show-contact.css">
   
</head>
<body>

<header class="app-header">
    <h1 class="app-brand">CONTACT APP</h1>
</header>

<div class="container-fluid">
    <div class="card">
        <!-- Header -->
        <div class="card-header">
            <h4>Contact Details</h4>
        </div>

        <!-- Body -->
        <div class="card-body">
            
            <!-- First Name -->
            <div class="row detail-row">
                <div class="col-sm-3 detail-label">First Name</div>
                <div class="col-sm-9 detail-value"><%= contact.first_name  %></div>
            </div>

            <!-- Last Name -->
            <div class="row detail-row">
                <div class="col-sm-3 detail-label">Last Name</div>
                <div class="col-sm-9 detail-value"><%= contact.last_name  %></div>
            </div>

            <!-- Email -->
            <div class="row detail-row">
                <div class="col-sm-3 detail-label">Email</div>
                <div class="col-sm-9 detail-value"><%= contact.email  %></div>
            </div>

            <!-- Phone -->
            <div class="row detail-row">
                <div class="col-sm-3 detail-label">Phone</div>
                <div class="col-sm-9 detail-value"><%= contact.phone  %></div>
            </div>

            <!-- Address -->
            <div class="row detail-row">
                <div class="col-sm-3 detail-label">Address</div>
                <div class="col-sm-9 detail-value"><%= contact.address  %></div>
            </div>

            <hr>

            <!-- Actions -->
            <div class="row mt-3">
                <div class="col-sm-3"></div>
                <div class="col-sm-9">
                    <a href="/update-contact/<%= contact._id  %>" class="btn btn-custom btn-edit-action me-2">Edit</a>
                    <a href="/delete-contact/<%= contact._id  %>" class="btn btn-custom btn-delete-action me-2">Delete</a>
                    <a href="/" class="btn btn-custom btn-cancel-action">Cancel</a>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap 5 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>