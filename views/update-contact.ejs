<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Contact</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/add-contact.css">
    
</head>
<body>

<div class="container-fluid">
    <div class="card">
        <!-- Header -->
        <div class="card-header">
            <h4>Update Contact</h4>
        </div>

        <!-- Form Body -->
        <div class="card-body">
            <form action="/update-contact/<%= contact._id  %>" method="POST">
                
                <!-- First Name -->
                <div class="row mb-4 align-items-center">
                    <label for="firstName" class="col-sm-3 col-form-label">First Name</label>
                    <div class="col-sm-9">
                        <input type="text" name="first_name" value="<%= contact.first_name  %>" class="form-control" id="firstName">
                    </div>
                </div>

                <!-- Last Name -->
                <div class="row mb-4 align-items-center">
                    <label for="lastName" class="col-sm-3 col-form-label">Last Name</label>
                    <div class="col-sm-9">
                        <input type="text" name="last_name" value="<%= contact.last_name  %>" class="form-control" id="lastName">
                    </div>
                </div>

                <!-- Email -->
                <div class="row mb-4 align-items-center">
                    <label for="email" class="col-sm-3 col-form-label">Email</label>
                    <div class="col-sm-9">
                        <input type="email" name="email" value="<%= contact.email  %>" class="form-control" id="email">
                    </div>
                </div>

                <!-- Phone -->
                <div class="row mb-4 align-items-center">
                    <label for="phone" class="col-sm-3 col-form-label">Phone</label>
                    <div class="col-sm-9">
                        <input type="text" name="phone" value="<%= contact.phone  %>" class="form-control" id="phone">
                    </div>
                </div>

                <!-- Address -->
                <div class="row mb-4">
                    <label for="address" class="col-sm-3 col-form-label">Address</label>
                    <div class="col-sm-9">
                        <textarea class="form-control" name="address" id="address" rows="4"><%= contact.address  %></textarea>
                    </div>
                </div>

                <hr>

                <!-- Actions -->
                <div class="row mt-3">
                    <div class="col-sm-3"></div>
                    <div class="col-sm-9">
                        <button type="submit" class="btn btn-save me-2">Save</button>
                        <a href="/" class="btn btn-cancel">Cancel</a>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- Bootstrap 5 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>