<%- include('partials/header', { title: 'Add New Contact' }) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            
            <div class="d-flex align-items-center mb-4 gap-3">
                <a href="/" class="btn btn-outline-custom rounded-circle" style="width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; padding: 0;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="mb-0 fw-bold text-dark">Add New Contact</h2>
            </div>
            
            <div class="glass-card p-4 p-md-5 bg-white border-0 shadow-sm">
                <form action="/add-contact" method="POST" class="needs-validation">
                    
                    <div class="row gx-4 mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label for="firstName" class="form-label text-secondary fw-semibold">First Name</label>
                            <input type="text" name="first_name" class="form-control form-control-lg fs-6 bg-light" id="firstName" placeholder="e.g. Jane" required>
                        </div>
                        <div class="col-md-6">
                            <label for="lastName" class="form-label text-secondary fw-semibold">Last Name</label>
                            <input type="text" name="last_name" class="form-control form-control-lg fs-6 bg-light" id="lastName" placeholder="e.g. Doe" required>
                        </div>
                    </div>

                    <div class="row gx-4 mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label for="email" class="form-label text-secondary fw-semibold">Email Address</label>
                            <input type="email" name="email" class="form-control form-control-lg fs-6 bg-light" id="email" placeholder="jane.doe@example.com" required>
                        </div>
                        <div class="col-md-6">
                            <label for="phone" class="form-label text-secondary fw-semibold">Phone Number</label>
                            <input type="tel" name="phone" class="form-control form-control-lg fs-6 bg-light" id="phone" placeholder="+1 (555) 000-0000" required>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label for="address" class="form-label text-secondary fw-semibold">Physical Address</label>
                        <textarea class="form-control form-control-lg fs-6 bg-light" name="address" id="address" rows="3" placeholder="Enter complete address..." required></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-3 pt-3 mt-3 border-top pb-1">
                        <a href="/" class="btn btn-outline-custom px-4 d-flex align-items-center">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary-custom d-flex align-items-center gap-2 px-5 shadow-sm">
                            Save Contact
                        </button>
                    </div>
                </form>
            </div>
            
        </div>
    </div>
</div>

<%- include('partials/footer') %>